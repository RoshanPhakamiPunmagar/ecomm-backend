@rootURL = http://localhost:3000
@apiEP = {{rootURL}}/api/customer/v1
@authEP = {{apiEP}}/auth

@productsEP = {{apiEP}}/products

@categoriesEP = {{apiEP}}/categories

@ordersEP = {{apiEP}}/orders

# Customer Backend APIs (Base: /api/customer/v1/)
# Authentication APIs:
# POST /api/customer/v1/auth/signup
# POST /api/customer/v1/auth/login     
# GET /api/customer/v1/auth/verify/:token
# POST /api/customer/v1/auth/refresh-token
# Product APIs:



### Signup API
POST {{authEP}}/signup
Content-Type: application/json

{
  "email": "customer1@gmail.com",
  "password": "Password123"
}


### login API
POST {{authEP}}/login
Content-Type: application/json

{
    "email" : "customer1@gmail.com",
    "password" : "Password123"
}

### renew jwt
GET {{authEP}}/verify/:token
Authorization: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6ImN1c3RvbWVyMUBnbWFpbC5jb20iLCJpYXQiOjE3NjY4MTYzMjksImV4cCI6MTc2OTQwODMyOX0.WWfdpn54OA-1Zpil4IFTuKjzBvTBg1rMyJ3DuA7jqFk

### refresh token
POST {{authEP}}/refresh-token
Authorization: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6ImN1c3RvbWVyMUBnbWFpbC5jb20iLCJpYXQiOjE3NjY4MTYzMjksImV4cCI6MTc2OTQwODMyOX0.WWfdpn54OA-1Zpil4IFTuKjzBvTBg1rMyJ3DuA7jqFk

# Product APIs:
### GET /api/customer/v1/products (Get all products with filters/pagination)
GET {{productsEP}}

### GET products with pagination
GET {{productsEP}}?page=1&limit=2

###
GET {{productsEP}}?minPrice=500&maxPrice=1500

###
GET {{productsEP}}?sortBy=price&order=asc

###
GET {{productsEP}}?sortBy=createdAt&order=desc

### GET single product by its ID
GET {{productsEP}}/695a21df27ad281b903a6193

### Get all categories
GET {{categoriesEP}}


### Place order
POST {{ordersEP}}
Authorization: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6ImN1c3RvbWVyMUBnbWFpbC5jb20iLCJpYXQiOjE3NjgzNzc5NTQsImV4cCI6MTc2ODQ2NDM1NH0.Xb4PF9zo9fMlWv82hgBnd9tE8FV-tVGLQMWyHjKRktM
Content-Type: application/json

{
  "products": [
    {
      "productId": "695a21df27ad281b903a6193",
      "quantity": 2
    },
    {
      "productId": "695a23c827ad281b903a619b",
      "quantity": 1
    }
  ]
}

### Get my orders
GET {{ordersEP}}?userId=694e49cc7d170da8829b3209
Authorization: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6ImN1c3RvbWVyMUBnbWFpbC5jb20iLCJpYXQiOjE3NjgzNzc5NTQsImV4cCI6MTc2ODQ2NDM1NH0.Xb4PF9zo9fMlWv82hgBnd9tE8FV-tVGLQMWyHjKRktM

### POST /api/customer/v1/reviews
Authorization: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6ImN1c3RvbWVyMUBnbWFpbC5jb20iLCJpYXQiOjE3NjkyNTUyNTEsImV4cCI6MTc2OTM0MTY1MX0.2QL58XINUy5MGsdR516c2bL5M07_qafqlC5Zy-YGvRY
